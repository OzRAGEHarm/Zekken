use fs; // file system library

let file_path: string = "data.txt";
let copy_path: string = "data_copy.txt";
let moved_path: string = "data_moved.txt";
let dir_path: string = "test_dir";

// Write + append
fs.write_file => |file_path, "line1\nline2"|
fs.append_file => |file_path, "\nline3"|

let data: string = fs.read_file => |file_path|;
@println => |"File data: " + data|

let lines: arr = fs.read_lines => |file_path|;
@println => |"Read lines: " + lines|

// Copy + stat + rename
let copied_bytes: int = fs.copy_file => |file_path, copy_path|;
@println => |"Bytes copied: " + copied_bytes|

let stats: obj = fs.stat => |copy_path|;
@println => |"Stat size: " + stats.size|
@println => |"Stat is_file: " + stats.is_file|
@println => |"Stat readonly: " + stats.readonly|
@println => |"Stat modified_unix: " + stats.modified_unix|

fs.rename => |copy_path, moved_path|
let moved_exists: bool = fs.exists => |moved_path|;
@println => |"Moved exists: " + moved_exists|

// Directory + path checks
fs.create_dir => |dir_path|
let dir_exists: bool = fs.exists => |dir_path|;
let path_is_file: bool = fs.is_file => |file_path|;
let path_is_dir: bool = fs.is_dir => |dir_path|;
@println => |"Dir exists: " + dir_exists|
@println => |"Is file: " + path_is_file|
@println => |"Is dir: " + path_is_dir|

let dir_entries: arr = fs.read_dir => |"tests"|;
@println => |"Read dir entries: " + dir_entries|

// Cleanup
fs.remove_file => |file_path|
fs.remove_file => |moved_path|
fs.remove_dir => |dir_path|

let file_exists_after: bool = fs.exists => |file_path|;
let moved_exists_after: bool = fs.exists => |moved_path|;
let dir_exists_after: bool = fs.exists => |dir_path|;
@println => |"File exists after cleanup: " + file_exists_after|
@println => |"Moved file exists after cleanup: " + moved_exists_after|
@println => |"Dir exists after cleanup: " + dir_exists_after|
@println => |"All tests for the fs library complete!"|
