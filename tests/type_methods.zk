@println => |"String Methods:\n"|

let str: string = "Hello, World!";
@println => |"String: '" + str + "'"|

let len: int = str.length => | |; // 13
@println => |"String Length: " + len|

let upper: string = str.toUpper => | |; // "HELLO, WORLD!"
@println => |"Uppercase String: '" + upper + "'"|

let lower: string = str.toLower => | |; // "hello, world!"
@println => |"Lowercase String: '" + lower + "'"|

let trimmed: string = str.trim => | |; // "Hello, World!"
@println => |"Trimmed String: '" + trimmed + "'"|

let split: arr = str.split => |","|; // ["Hello", " World!"]
@println => |"Split String: " + split|

@println => |"\nArray Methods:\n"|

let array: arr = [1, 2, 3];
@println => |"Array (before): " + array|
array.push => |4| // [1, 2, 3, 4]
@println => |"Array (after push): " + array|

let popped: int = array.pop => | |; // 4
@println => |"Popped Element: " + popped|
@println => |"Array (after pop): " + array| // [1, 2, 3]

let joined: string = array.join => |"-"|; // "1-2-3"
@println => |"Joined Array: " + joined|

let first: int = array.first => | |; // 1
@println => |"First Element of Array: " + first|

let last: int = array.last => | |; // 3
@println => |"Last Element of Array: " + last|

@println => |"\nObject Methods:\n"|

let object: obj = { name: "John", age: 30 };
@println => |"Object: " + object|

let keys: arr = object.keys => | |; // ["name", "age"]
@println => |"Object Keys: " + keys|

let values: arr = object.values => | |; // ["John", 30]
@println => |"Object Values: " + values|

// If entries method is supported:
let entries: arr = object.entries => | |; // [["name", "John"], ["age", 30]]
@println => |"Object Entries: " + entries|

@println => |"\nInt/Float Methods:\n"|

let num: float = 3.7;
@println => |"Number: " + num|

let rounded: int = num.round => | |; // 4
@println => |"Number Rounded: " + rounded|

let floored: int = num.floor => | |; // 3
@println => |"Number Floored: " + floored|

let ceil: int = num.ceil => | |; // 4
@println => |"Number Ceil: " + ceil|

let even: bool = num.isEven => | |; // false
@println => |"Is Number Even: " + even|

@println => |"\nType Casting Methods:\n"|

// String casts
@println => |"String Casts:"|
let str_num: string = "-42";
let cast_str_to_int: int = str_num.cast => |"int"|;
let cast_str_to_float: float = str_num.cast => |"float"|;
let cast_str_to_bool: bool = "true".cast => |"bool"|;
@println => |"String to int: " + cast_str_to_int|
@println => |"String to float: " + cast_str_to_float|
@println => |"String to bool: " + cast_str_to_bool|

// Int casts
@println => |"\nInteger Casts:"|
let int_val: int = -15;
let cast_int_to_string: string = int_val.cast => |"string"|;
let cast_int_to_float: float = int_val.cast => |"float"|;
let cast_int_to_bool: bool = int_val.cast => |"bool"|;
@println => |"Int to string: " + cast_int_to_string|
@println => |"Int to float: " + cast_int_to_float|
@println => |"Int to bool: " + cast_int_to_bool|

// Float casts
@println => |"\nFloat Casts:"|
let float_val: float = -7.9;
let cast_float_to_int: int = float_val.cast => |"int"|; // truncates
let cast_float_to_string: string = float_val.cast => |"string"|;
let cast_float_to_bool: bool = float_val.cast => |"bool"|;
@println => |"Float to int: " + cast_float_to_int|
@println => |"Float to string: " + cast_float_to_string|
@println => |"Float to bool: " + cast_float_to_bool|

// Bool casts
@println => |"\nBool Casts:"|
let bool_val: bool = false;
let cast_bool_to_int: int = bool_val.cast => |"int"|;
let cast_bool_to_float: float = bool_val.cast => |"float"|;
let cast_bool_to_string: string = bool_val.cast => |"string"|;
@println => |"Bool to int: " + cast_bool_to_int|
@println => |"Bool to float: " + cast_bool_to_float|
@println => |"Bool to string: " + cast_bool_to_string|

// Invalid cast example
try {
  let bad_cast: int = "Hello".cast => |"int"|;
  @println => |bad_cast|
} catch |e| {
  @println => |"Invalid cast handled: " + e.message|
}

@println => |"\nAll type method tests complete!"|
